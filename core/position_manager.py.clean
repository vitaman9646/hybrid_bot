            # Feature Logger: логируем outcome
            if hasattr(pos, 'signal_id') and pos.signal_id and hasattr(self, '_feature_logger'):
                duration = time.time() - pos.timestamp
                self._feature_logger.log_outcome(
                    signal_id=pos.signal_id,
                    entry_price=pos.entry_price,
                    exit_price=current_price if current_price > 0 else pos.entry_price,
                    pnl_pct=pnl_pct if 'pnl_pct' in locals() else 0.0,
