                    exit_reason=reason,
                    duration_sec=duration,
                    mae_pct=getattr(pos, 'mae', None),
                    mfe_pct=getattr(pos, 'mfe', None),
                )
            return (pos.close_price - pos.entry_price) / pos.entry_price * pos.qty * pos.entry_price
