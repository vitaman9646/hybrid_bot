aggregator:
  entry_threshold: 0.3
  imbalance_threshold: 0.55
  mode: weighted
  scenario4_vol_max: 3.0
  scenario4_vol_min: 0.1
  signal_cooldown: 10.0
  use_imbalance_filter: false
  weight_averages: 0.3
  weight_depth: 0.2
  weight_vector: 0.5
analyzers:
  averages:
    long_period: 300.0
    min_delta_pct: 0.05
    overbought_delta: 0.8
    oversold_delta: -0.8
    short_period: 60.0
  depth_shot:
    buffer_pct: 0.2
    max_distance_pct: 2.5
    min_distance_pct: 0.1
    min_volume_usdt: 200000
    stop_if_outside: true
    tp_pct: 0.3
    tp_type: classic
  vector:
    chaos_threshold: 5.0
    dead_threshold: 0.001
    frame_size: 0.2
    min_quote_volume: 100
    min_spread_size: 0.003
    min_trades_per_frame: 1
    time_frame: 0.6
    use_detect_shot: false
dynamic_weights:
  enabled: true
  min_signals_required: 50
  store_in: memory
  update_interval: 14400
filters:
  delta:
  - range:
    - 0.3
    - 5.0
    timeframe: 5m
    type: absolute
  - range:
    - 0.5
    - 10.0
    timeframe: 1h
    type: absolute
  funding:
    adaptive:
      enabled: true
      long_pause_above: 0.1
      short_pause_below: -0.1
    pause_after: 60
    pause_before: 60
    range:
    - -0.5
    - 0.5
  mark_price:
    range:
    - -0.5
    - 0.5
  volatility:
    chaos_threshold: 5.0
    dead_market_threshold: 0.05
  volume_24h:
    max: 999999999999
    min: 5000000
min_partial_sources: 2
min_score: 0.55
mode: weighted
name: Hybrid Trend Impulse v1
order:
  direction: auto
  grid:
    count: 3
    distance: 0.3
    enabled: false
    increase: 50
  max_drawdown_pct: 5.0
  second_sl:
    distance: 0.2
    enabled: true
    trigger: 0.5
  size_usdt: 50
  stop_loss:
    delay: 0
    percent: 1.5
    spread: 0.1
    type: market
  take_profit:
    auto_reduce:
      enabled: true
      step: 0.1
      threshold: 0.2
      timer: 30
    percent: 0.8
    type: classic
  trailing:
    adaptive: true
    enabled: true
    spread: 0.3
  type: limit

risk:
  position_pct: 2.0              # % от баланса на позицию
  daily_loss_limit_usdt: 50.0    # стоп на день
  corr_block_enabled: true       # блок коррелирующих символов
  min_size_usdt: 5.0
  max_size_usdt: 500.0
  drawdown_tiers:                # снижение размера при просадке
    - [0.0,  1.00]
    - [-1.0, 0.50]
    - [-2.0, 0.25]
    - [-3.0, 0.00]
