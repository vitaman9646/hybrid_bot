exchange:
  api_key: QhcgvVUWMQc8Iaz2EN
  api_secret: iiv1TP6TECXr6GZ71XsfsI14V3YKyvSXZQdm
  max_retries: 3
  name: bybit
  rate_limit: 950
  retry_delay: 0.1
  testnet: false
  paper_mode: true
  ws_channel_type: linear
  ws_max_reconnect_attempts: 50
  ws_ping_interval: 20
  ws_reconnect_delay: 5
  ws_trace_logging: false
filter_pipeline:
  correlation_filter_enabled: true
  delta_filter_enabled: true
  funding_filter_enabled: true
  mark_filter_enabled: true
  max_mark_deviation_pct: 0.5
  min_delta_usdt: 10000
  min_volume_usdt: 100000
  time_filter_enabled: false
  volume_filter_enabled: true
health_check:
  enabled: true
  port: 8080
latency:
  check_interval: 5
  critical_threshold_ms: 500
  emergency_threshold_ms: 1000
  rtt_window_size: 100
  track_order_rtt: true
  warn_threshold_ms: 300
logging:
  backup_count: 5
  file: logs/bot.log
  format: '%(asctime)s [%(levelname)s] %(name)s: %(message)s'
  level: INFO
  max_size_mb: 50
monitoring:
  telegram:
    alert_on_error: true
    alert_on_latency: true
    alert_on_trade: true
    bot_token: 8741859170:AAExdEaMLBYA5FotU2RFIgw9rMxRucYNb_I
    chat_id: 1066756284
    enabled: true
pairs:
  market_type: futures
  max_active: 15
  quote: usdt
  symbols:
  - BTCUSDT
  - ETHUSDT
  - SOLUSDT
  - XRPUSDT
  - DOGEUSDT
  - AVAXUSDT
storage:
  market_db: data/market.db
strategy:
  analyzers:
    vector:
      min_quote_volume: 500
      min_spread_size: 0.005
      frame_size: 2.0
      dead_threshold: 0.001
      chaos_threshold: 0.05
      min_trades_per_frame: 1

  depth_shot_v2:
    wall_min_age_s: 5.0
    wall_max_drop_pct: 0.35
    min_distance_pct: 0.15
    max_distance_pct: 2.0
    max_walls: 3
    cluster_pct: 0.05
    tp_pct_fallback: 0.3
    ladder_distribution: [0.40, 0.35, 0.25]
    symbol_thresholds:
      BTCUSDT: 150000
      ETHUSDT: 80000
      SOLUSDT: 40000
      BNBUSDT: 40000
      XRPUSDT: 20000
      DOGEUSDT: 20000
      ADAUSDT: 20000
      AVAXUSDT: 20000

  momentum_fade:
    window_s: 8.0
    fade_threshold: 0.25
    min_profit_pct: 0.10
    confirm_s: 3.0
    min_ticks: 10
    max_loss_pct: 0.05

  time_stop_sec: 1800

risk:
  risk_per_trade_pct: 1.5
  position_pct: 15.0
  sl_pct_default: 1.2
  min_size_usdt: 5.0
  max_size_usdt: 200.0
  max_trades_per_day: 50
  max_concurrent_positions: 4
  max_consecutive_losses: 3
  consecutive_loss_size_mult: 0.5
  daily_loss_limit_pct: 2.0
  score_sizing_enabled: true
  score_size_min_mult: 0.6
  score_size_max_mult: 1.4
  daily_profit_boost: 1.2
  daily_loss_reduce: 0.5
paper_mode: true

# === Signal Aggregator ===
signal_aggregator:
  mode: weighted
  opposite_exit_enabled: true
  opposite_close_threshold: 0.55
  opposite_reverse_threshold: 0.75
  cooldown_after_tp: 180
  cooldown_after_sl: 300
  weights:
    vector: 0.4
    averages: 0.35
    depth: 0.25
  scenarios:
    all_three:
      threshold: 0.40
      sessions: [LONDON, NY, ASIA, QUIET, DEAD]
    averages_vector:
      threshold: 0.65
      sessions: [LONDON, NY]
    averages_depth:
      threshold: 0.65
      sessions: [LONDON, NY]
    vector_depth:
      threshold: 0.60
      sessions: [LONDON, NY, QUIET]

# === Session Filter ===
session_filter:
  enabled: true
  sessions:
    DEAD:
      start_hour: 0
      end_hour: 6
      multiplier: 0.0
    ASIA:
      start_hour: 6
      end_hour: 8
      multiplier: 0.5
    LONDON:
      start_hour: 8
      end_hour: 13
      multiplier: 1.0
    NY:
      start_hour: 13
      end_hour: 18
      multiplier: 1.0
    QUIET:
      start_hour: 18
      end_hour: 24
      multiplier: 0.3

# === Regime Filter ===
regime_filter:
  enabled: true
  regimes:
    TRENDING:
      scenarios: [all_three, averages_vector, vector_depth]
      multiplier: 1.1
    RANGING:
      scenarios: [averages_depth, all_three]
      multiplier: 1.0
    VOLATILE:
      scenarios: [vector_depth]
      multiplier: 0.8
